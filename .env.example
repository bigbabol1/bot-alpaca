# ── Alpaca ────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# "paper" (default) or "live"
# IMPORTANT: live mode also requires: touch /app/data/.live_mode_confirmed
TRADING_MODE=paper

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://192.168.0.66:11434
OLLAMA_DECISION_MODEL=qwen2.5:32b
OLLAMA_TRIAGE_MODEL=qwen2.5:7b
# Set true only when a second GPU/host is available for the triage model
TWO_STAGE_LLM=false

# ── Risk profile ───────────────────────────────────────────────────────────────
# conservative | moderate | aggressive  (also hot-reloadable via config/trading_params.yml)
RISK_PROFILE=conservative

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8080
# Comma-separated IPs allowed to access dashboard (empty = any LAN IP)
ALLOWED_IPS=
